# Docker Environment Variables
DB_HOST=db
DB_USER=photo_user
DB_PASSWORD=secure_password_change_me
DB_NAME=photo_sharing_db
DB_PORT=3306

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Configuration
JWT_SECRET=your_very_secure_secret_key_change_in_production
JWT_EXPIRATION=24h

# CORS Configuration (change to your Svelte app URL)
CORS_ORIGIN=http://localhost:5173

# Admin Panel
ADMIN_SECRET=your_admin_secret_key_change_in_production
